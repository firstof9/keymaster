{
  "compilerOptions": {
    "baseUrl": ".",
    "experimentalDecorators": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "*": ["./node_modules/*"]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "ignoreDeprecations": "5.0",
    "target": "es2022",
    "useDefineForClassFields": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["lovelace_strategy/**/*", "tsconfig.json", "rollup.config.js"]
}
